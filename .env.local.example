# ============================================================
# CD Media — Biến môi trường Supabase
# ------------------------------------------------------------
# 1. Copy file này thành .env.local (bỏ đuôi .example)
# 2. Vào https://supabase.com → tạo project (miễn phí)
# 3. Vào Project Settings → API, copy các giá trị dưới đây
# ============================================================

# URL project (dạng https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# anon / public key — dùng ở trình duyệt, an toàn để lộ (RLS bảo vệ)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role key — CHỈ dùng cho script migrate, KHÔNG bao giờ để lộ ra client
# (chỉ cần khi chạy script chuyển dữ liệu cũ vào DB)
SUPABASE_SERVICE_ROLE_KEY=
